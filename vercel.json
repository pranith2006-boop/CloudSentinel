{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/css/(.+)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.+)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/(login\\.html|dashboard\\.html|portal\\.html|reports\\.html|docs\\.html|about\\.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}
